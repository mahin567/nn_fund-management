<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="rule_fund_account_company" model="ir.rule">
            <field name="name">Fund Account: multi-company</field>
            <field name="model_id" ref="model_fund_account"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_fund_incoming_company" model="ir.rule">
            <field name="name">Incoming Fund: multi-company</field>
            <field name="model_id" ref="model_fund_incoming"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_fund_allocation_company" model="ir.rule">
            <field name="name">Fund Allocation: multi-company</field>
            <field name="model_id" ref="model_fund_allocation"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_fund_requisition_company" model="ir.rule">
            <field name="name">Fund Requisition: multi-company</field>
            <field name="model_id" ref="model_fund_requisition"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_fund_bill_company" model="ir.rule">
            <field name="name">Fund Bill: multi-company</field>
            <field name="model_id" ref="model_fund_bill"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_fund_transfer_company" model="ir.rule">
            <field name="name">Fund Transfer: multi-company</field>
            <field name="model_id" ref="model_fund_transfer"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Fund Users can only see their own requests; approvers/admin see all -->
        <record id="rule_fund_allocation_own_records" model="ir.rule">
            <field name="name">Fund Allocation: own records only for Fund User</field>
            <field name="model_id" ref="model_fund_allocation"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <record id="rule_fund_requisition_own_records" model="ir.rule">
            <field name="name">Fund Requisition: own records only for Fund User</field>
            <field name="model_id" ref="model_fund_requisition"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

        <record id="rule_fund_transfer_own_records" model="ir.rule">
            <field name="name">Fund Transfer: own records only for Fund User</field>
            <field name="model_id" ref="model_fund_transfer"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
        </record>

    </data>
</odoo>
