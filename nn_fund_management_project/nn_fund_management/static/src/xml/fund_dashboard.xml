<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="fund_management.DashboardTemplate">
    <div class="o_fund_dashboard">

        <!-- Header -->
        <div class="o_fund_dashboard_header">
            <h2 class="o_fund_dashboard_title">
                <i class="fa fa-tachometer me-2"/>Fund Management Dashboard
            </h2>
            <button class="btn btn-sm btn-outline-secondary" t-on-click="_reload">
                <i class="fa fa-refresh"/> Refresh
            </button>
        </div>

        <!-- Loading -->
        <t t-if="state.loading">
            <div class="o_fund_dashboard_loading">
                <i class="fa fa-spinner fa-spin fa-2x"/>
                <p class="mt-2 text-muted">Loading dashboard…</p>
            </div>
        </t>

        <t t-elif="state.data">
            <t t-set="d" t-value="state.data"/>

            <!-- KPI Row -->
            <div class="o_fund_kpi_row">

                <div class="o_fund_kpi_card o_kpi_blue">
                    <div class="o_kpi_label">Total Received</div>
                    <div class="o_kpi_value"><t t-esc="fmt(d.total_received)"/></div>
                </div>

                <div class="o_fund_kpi_card o_kpi_green">
                    <div class="o_kpi_label">Unassigned Balance</div>
                    <div class="o_kpi_value"><t t-esc="fmt(d.total_unassigned)"/></div>
                </div>

                <div class="o_fund_kpi_card o_kpi_yellow">
                    <div class="o_kpi_label">On Hold</div>
                    <div class="o_kpi_value"><t t-esc="fmt(d.total_held)"/></div>
                </div>

                <div class="o_fund_kpi_card o_kpi_purple">
                    <div class="o_kpi_label">Total Assigned</div>
                    <div class="o_kpi_value"><t t-esc="fmt(d.total_assigned)"/></div>
                </div>

                <div class="o_fund_kpi_card o_kpi_red">
                    <div class="o_kpi_label">Total Spent</div>
                    <div class="o_kpi_value"><t t-esc="fmt(d.total_spent)"/></div>
                </div>

            </div>

            <!-- Pending Approvals -->
            <div class="o_fund_section_title">Pending Approvals</div>
            <div class="o_fund_pending_row">

                <div class="o_fund_pending_card" t-on-click="openAllocations">
                    <div class="o_pending_count"><t t-esc="d.pending_allocations"/></div>
                    <div class="o_pending_label">Allocations</div>
                    <i class="fa fa-arrow-circle-right o_pending_icon"/>
                </div>

                <div class="o_fund_pending_card" t-on-click="openRequisitions">
                    <div class="o_pending_count"><t t-esc="d.pending_requisitions"/></div>
                    <div class="o_pending_label">Requisitions</div>
                    <i class="fa fa-arrow-circle-right o_pending_icon"/>
                </div>

                <div class="o_fund_pending_card" t-on-click="openTransfers">
                    <div class="o_pending_count"><t t-esc="d.pending_transfers"/></div>
                    <div class="o_pending_label">Transfers</div>
                    <i class="fa fa-arrow-circle-right o_pending_icon"/>
                </div>

                <div class="o_fund_pending_card o_pending_verify" t-on-click="openPendingVerification">
                    <div class="o_pending_count"><t t-esc="d.pending_verifications"/></div>
                    <div class="o_pending_label">Bank Verifications</div>
                    <i class="fa fa-arrow-circle-right o_pending_icon"/>
                </div>

            </div>

            <!-- Charts Row -->
            <div class="o_fund_charts_row">
                <div class="o_fund_chart_card">
                    <div class="o_fund_section_title">Monthly Incoming Funds</div>
                    <canvas t-ref="incomeChart" height="180"/>
                </div>
                <div class="o_fund_chart_card">
                    <div class="o_fund_section_title">Top Projects by Available Fund</div>
                    <canvas t-ref="projectChart" height="180"/>
                </div>
            </div>

            <!-- Top Expense Heads -->
            <div class="o_fund_section_title mt-3">Top Expense Heads</div>
            <table class="table table-sm o_fund_table">
                <thead>
                    <tr>
                        <th>Expense Head</th>
                        <th class="text-end">Allocated</th>
                        <th class="text-end">Available</th>
                        <th class="text-end">Spent</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="d.top_expense_heads" t-as="head" t-key="head.name">
                        <tr>
                            <td><t t-esc="head.name"/></td>
                            <td class="text-end"><t t-esc="fmt(head.allocated)"/></td>
                            <td class="text-end text-success fw-bold"><t t-esc="fmt(head.available)"/></td>
                            <td class="text-end text-danger"><t t-esc="fmt(head.spent)"/></td>
                        </tr>
                    </t>
                    <tr t-if="!d.top_expense_heads.length">
                        <td colspan="4" class="text-muted text-center">No expense heads with funds</td>
                    </tr>
                </tbody>
            </table>

            <!-- Recent Activity -->
            <div class="o_fund_section_title mt-3">Recent Activity</div>
            <table class="table table-sm o_fund_table">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>By</th>
                        <th class="text-end">Amount</th>
                        <th>Date</th>
                        <th>Comment</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="d.recent_activity" t-as="act" t-key="act_index">
                        <tr>
                            <td><span class="badge bg-secondary"><t t-esc="act.action"/></span></td>
                            <td><t t-esc="act.actor"/></td>
                            <td class="text-end"><t t-esc="fmt(act.amount)"/></td>
                            <td><t t-esc="act.date"/></td>
                            <td class="text-muted"><t t-esc="act.comment"/></td>
                        </tr>
                    </t>
                    <tr t-if="!d.recent_activity.length">
                        <td colspan="5" class="text-muted text-center">No recent activity</td>
                    </tr>
                </tbody>
            </table>

        </t>
    </div>
</t>

</templates>
