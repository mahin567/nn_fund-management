<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_approval_rule_tree" model="ir.ui.view">
            <field name="name">fund.approval.rule.tree</field>
            <field name="model">fund.approval.rule</field>
            <field name="arch" type="xml">
                <tree string="Approval Rules" decoration-muted="not active">
                    <field name="name"/>
                    <field name="transaction_type"/>
                    <field name="min_amount"/>
                    <field name="max_amount"/>
                    <field name="require_gm"/>
                    <field name="require_md"/>
                    <field name="gm_approver_id"/>
                    <field name="md_approver_id"/>
                    <field name="active" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_approval_rule_form" model="ir.ui.view">
            <field name="name">fund.approval.rule.form</field>
            <field name="model">fund.approval.rule</field>
            <field name="arch" type="xml">
                <form string="Approval Rule">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active"/>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="e.g. Large Allocation > 500,000"/></h1>
                        </div>
                        <group>
                            <group string="Scope">
                                <field name="transaction_type"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="active"/>
                            </group>
                            <group string="Amount Range">
                                <field name="min_amount"/>
                                <field name="max_amount"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <group string="Approval Levels">
                            <group>
                                <field name="require_gm"/>
                                <field name="gm_approver_id"
                                       invisible="not require_gm"
                                       placeholder="Any user in GM Approver group"/>
                            </group>
                            <group>
                                <field name="require_md"/>
                                <field name="md_approver_id"
                                       invisible="not require_md"
                                       placeholder="Any user in MD Approver group"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="description" nolabel="1" placeholder="Describe when this rule applies…"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_fund_approval_rule" model="ir.actions.act_window">
            <field name="name">Approval Rules</field>
            <field name="res_model">fund.approval.rule</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first amount-based approval rule
                </p>
                <p>
                    Rules override the default GM→MD workflow for requests that
                    match the amount range and transaction type.
                </p>
            </field>
        </record>
    </data>

</odoo>
