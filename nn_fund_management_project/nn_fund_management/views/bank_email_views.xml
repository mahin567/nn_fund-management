<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ══ Bank Email Template views ══════════════════════════════════════ -->

        <record id="view_fund_bank_email_template_tree" model="ir.ui.view">
            <field name="name">fund.bank.email.template.tree</field>
            <field name="model">fund.bank.email.template</field>
            <field name="arch" type="xml">
                <tree string="Bank Email Templates" decoration-muted="not active">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="subject_keywords"/>
                    <field name="default_fund_account_id"/>
                    <field name="active" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_bank_email_template_form" model="ir.ui.view">
            <field name="name">fund.bank.email.template.form</field>
            <field name="model">fund.bank.email.template</field>
            <field name="arch" type="xml">
                <form string="Bank Email Template">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active"/>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="e.g. BRAC Bank Credit Alert"/></h1>
                        </div>
                        <group>
                            <group string="Matching">
                                <field name="sequence"/>
                                <field name="active"/>
                                <field name="subject_keywords"
                                       placeholder="brac, credit alert  (comma-separated, case-insensitive)"/>
                            </group>
                            <group string="Default Fund Account">
                                <field name="default_fund_account_id"/>
                            </group>
                        </group>
                        <group string="Regex Patterns">
                            <field name="amount_regex"
                                   placeholder="(?:BDT|Tk\.?|TK)\s*([0-9,]+(?:\.[0-9]{1,2})?)"/>
                            <field name="ref_regex"
                                   placeholder="(?:Ref(?:erence)?[:\s#]+)([A-Z0-9\-]{6,30})"/>
                            <field name="sender_regex"
                                   placeholder="(?:Sender|From)[:\s]+([^\n\r,]+)  (optional)"/>
                        </group>
                        <group string="Notes">
                            <field name="description" nolabel="1"
                                   placeholder="Describe the email format this template handles…"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_fund_bank_email_template" model="ir.actions.act_window">
            <field name="name">Bank Email Templates</field>
            <field name="res_model">fund.bank.email.template</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add a bank email parsing template
                </p>
                <p>
                    Each template defines regex patterns to extract amount,
                    transaction reference, and sender from a bank notification email.
                    Templates are tried in sequence order; the first matching
                    subject keyword wins.
                </p>
            </field>
        </record>

        <!-- ══ Bank Email Log views ═══════════════════════════════════════════ -->

        <record id="view_fund_bank_email_log_tree" model="ir.ui.view">
            <field name="name">fund.bank.email.log.tree</field>
            <field name="model">fund.bank.email.log</field>
            <field name="arch" type="xml">
                <tree string="Bank Email Log"
                      decoration-success="status == 'parsed'"
                      decoration-danger="status == 'parse_error'"
                      decoration-warning="status == 'duplicate'"
                      decoration-muted="status == 'ignored'">
                    <field name="received_date"/>
                    <field name="name"/>
                    <field name="from_email"/>
                    <field name="template_used"/>
                    <field name="status"/>
                    <field name="incoming_fund_id"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_bank_email_log_form" model="ir.ui.view">
            <field name="name">fund.bank.email.log.form</field>
            <field name="model">fund.bank.email.log</field>
            <field name="arch" type="xml">
                <form string="Bank Email Log Entry">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="from_email"/>
                                <field name="received_date"/>
                                <field name="status"/>
                            </group>
                            <group>
                                <field name="template_used"/>
                                <field name="incoming_fund_id"/>
                                <field name="message_id"/>
                            </group>
                        </group>
                        <group string="Body Preview">
                            <field name="body_preview" nolabel="1" readonly="1"/>
                        </group>
                        <group string="Error Details" invisible="not error_details">
                            <field name="error_details" nolabel="1" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_fund_bank_email_log" model="ir.actions.act_window">
            <field name="name">Bank Email Log</field>
            <field name="res_model">fund.bank.email.log</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_filter_recent': 1}</field>
        </record>

        <!-- Show pending_verification incoming funds filtered view -->
        <record id="action_fund_incoming_pending" model="ir.actions.act_window">
            <field name="name">Pending Verification</field>
            <field name="res_model">fund.incoming</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('state', '=', 'pending_verification')]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No funds pending verification
                </p>
            </field>
        </record>
    </data>

</odoo>
