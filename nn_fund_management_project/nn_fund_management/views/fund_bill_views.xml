<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fund_bill_tree" model="ir.ui.view">
            <field name="name">fund.bill.tree</field>
            <field name="model">fund.bill</field>
            <field name="arch" type="xml">
                <tree string="Bills" decoration-success="state == 'posted'"
                      decoration-muted="state == 'cancelled'">
                    <field name="name"/>
                    <field name="requisition_id"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <field name="amount"/>
                    <field name="bill_date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_fund_bill_form" model="ir.ui.view">
            <field name="name">fund.bill.form</field>
            <field name="model">fund.bill</field>
            <field name="arch" type="xml">
                <form string="Fund Bill">
                    <header>
                        <button name="action_post" type="object" string="Post"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_cancel" type="object" string="Cancel"
                                invisible="state != 'posted'"
                                groups="nn_fund_management.group_fund_admin"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="requisition_id"/>
                                <field name="project_id" readonly="1"/>
                                <field name="expense_head_id" readonly="1"/>
                                <field name="amount"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="bill_date"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" invisible="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_fund_bill" model="ir.actions.act_window">
            <field name="name">Bills</field>
            <field name="res_model">fund.bill</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first bill
                </p>
            </field>
        </record>
    </data>

</odoo>
