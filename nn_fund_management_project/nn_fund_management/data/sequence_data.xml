<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_fund_incoming" model="ir.sequence">
            <field name="name">Incoming Fund</field>
            <field name="code">fund.incoming</field>
            <field name="prefix">INC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_fund_allocation" model="ir.sequence">
            <field name="name">Fund Allocation</field>
            <field name="code">fund.allocation</field>
            <field name="prefix">ALC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_fund_requisition" model="ir.sequence">
            <field name="name">Fund Requisition</field>
            <field name="code">fund.requisition</field>
            <field name="prefix">REQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_fund_bill" model="ir.sequence">
            <field name="name">Fund Bill</field>
            <field name="code">fund.bill</field>
            <field name="prefix">BILL/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_fund_transfer" model="ir.sequence">
            <field name="name">Fund Transfer</field>
            <field name="code">fund.transfer</field>
            <field name="prefix">TRF/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
