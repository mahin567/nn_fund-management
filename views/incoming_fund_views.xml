<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_incoming_tree" model="ir.ui.view">
        <field name="name">fund.incoming.tree</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <tree string="Incoming Funds" decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="transaction_reference"/>
                <field name="source"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">fund.incoming.form</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <form string="Incoming Fund">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state == 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="transaction_reference"/>
                        </group>
                        <group>
                            <field name="source"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="source_email_message_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="attachment" filename="attachment_filename"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">fund.incoming</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first incoming fund
            </p>
        </field>
    </record>

</odoo>
