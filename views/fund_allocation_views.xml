<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_allocation_tree" model="ir.ui.view">
        <field name="name">fund.allocation.tree</field>
        <field name="model">fund.allocation</field>
        <field name="arch" type="xml">
            <tree string="Fund Allocations" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount"/>
                <field name="request_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_allocation_form" model="ir.ui.view">
        <field name="name">fund.allocation.form</field>
        <field name="model">fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Fund Allocation">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_gm_approve" type="object" string="GM Approve"
                            class="btn-primary" invisible="state != 'submitted'"
                            groups="nn_fund_management.group_gm_approver"/>
                    <button name="action_md_approve" type="object" string="MD Approve"
                            class="btn-primary" invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_md_approver"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state not in ('submitted', 'gm_approved')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('rejected', 'cancelled', 'approved')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id"/>
                            <field name="project_id"/>
                            <field name="expense_head_id"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="requested_by"/>
                            <field name="request_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Purpose">
                        <field name="purpose" nolabel="1"/>
                        <field name="attachment" filename="attachment_filename"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                    <group string="GM Approval" invisible="state == 'draft'">
                        <field name="gm_approver_id" readonly="1"/>
                        <field name="gm_approval_date" readonly="1"/>
                        <field name="gm_comment" readonly="1"/>
                    </group>
                    <group string="MD Approval" invisible="state not in ('approved', 'rejected')">
                        <field name="md_approver_id" readonly="1"/>
                        <field name="md_approval_date" readonly="1"/>
                        <field name="md_comment" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="history_ids" readonly="1">
                                <tree>
                                    <field name="approval_level"/>
                                    <field name="actor_id"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                    <field name="action_date"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">fund.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first allocation request
            </p>
        </field>
    </record>

</odoo>
